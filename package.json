{
  "name": "fovea-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w fovea-web",
    "dev:admin": "npm run dev -w fovea-admin",
    "build:web": "npm run build -w fovea-web",
    "build:admin": "npm run build -w fovea-admin",
    "build:web:cloudflare": "npm run build:cloudflare -w fovea-web",
    "build:admin:cloudflare": "npm run build:cloudflare -w fovea-admin",
    "deploy:web": "npm run deploy -w fovea-web",
    "deploy:admin": "npm run deploy -w fovea-admin"
  }
}
